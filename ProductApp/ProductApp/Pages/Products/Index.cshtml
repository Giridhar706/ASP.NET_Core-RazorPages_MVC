@page
@model ProductApp.Pages.Products.IndexModel

<h2>Add Product</h2>

<form method="post">
    <input asp-for="NewProduct.Name" placeholder="Name" /><br />
    <input asp-for="NewProduct.Description" placeholder="Description" /><br />

    <input name="NewProduct.Categories[0].CategoryName" placeholder="Category 1" /><br />
    <input name="NewProduct.Categories[1].CategoryName" placeholder="Category 2" /><br />

    <button type="submit">Add</button>
</form>

<h2>Product List</h2>

@foreach (var item in ProductApp.Pages.Products.IndexModel.Products)
{
    <partial name="_ProductSummary" model="item" />

    <a asp-page="Details" asp-route-id="@item.ProductID">View Details</a>
    <hr />
}